// NoTrackSwitcher resources
// All IDs are numeric literals — no preprocessor needed (windres --no-cpp)

LANGUAGE 0, 0

// ID 1 = EXE file icon shown in Explorer (must be lowest numeric ID)
1   ICON "icon.ico"

// Tray icons referenced by code
101 ICON "icon.ico"
102 ICON "icon_off.ico"

STRINGTABLE
BEGIN
    501   "NoTrack Switcher"
    502   "Enable"
    503   "Disable"
END

// Settings dialog (IDD_SETTINGS = 301)
// STYLE: DS_SETFONT|DS_MODALFRAME|DS_CENTER|WS_POPUP|WS_CAPTION|WS_SYSMENU
301 DIALOGEX 0, 0, 240, 84
STYLE 0x80C008C0L
CAPTION "Settings"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    AUTOCHECKBOX "Start with Windows", 406, 12, 14, 150, 12

    LTEXT   "Fix selected text:", 423, 12, 36, 72, 10
    CONTROL "", 408, "msctls_hotkey32", 0x50810000L, 88, 34, 118, 13

    DEFPUSHBUTTON "OK",     1,   90, 62, 42, 14
    PUSHBUTTON    "Cancel", 2,  136, 62, 42, 14
END
